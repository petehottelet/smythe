flowchart TD
    financial["FinancialAnalyst: Analyze Acme Corp's revenue model, margins, burn rate, and comparable valuations"]
    technical["TechDiligenceAgent: Assess Acme Corp's IP portfolio, tech debt signals, and key-person dependencies"]
    regulatory["RegulatoryAgent: Review Acme Corp's SEC filings, antitrust exposure, and pending litigation"]
    draft["DiligenceEditor: Merge the specialist findings into a draft diligence report"]
    redteam["RedTeamAgent: Challenge every bullish claim in the draft report; stress-test projections and surface contradictions"]
    memo["MemoAgent: Produce the final structured memo: summary, findings, risks, recommendation - incorporating the red-team findings"]
    financial --> draft
    technical --> draft
    regulatory --> draft
    draft --> redteam
    draft --> memo
    redteam --> memo
    classDef done fill:#d3f9d8,stroke:#2b8a3e
    classDef failed fill:#ffe3e3,stroke:#c92a2a
    classDef skipped fill:#e9ecef,stroke:#868e96
    classDef running fill:#fff3bf,stroke:#e67700
    class financial,technical,regulatory,draft,redteam,memo done
