flowchart TD
    financial["FinancialAnalyst: Analyze MetaCortex Corp's revenue model, margins, burn rate, and comparable valuations"]
    technical["TechDiligenceAgent: Assess MetaCortex Corp's IP portfolio, tech debt signals, and key-person dependencies"]
    regulatory["RegulatoryAgent: Review MetaCortex Corp's SEC filings, antitrust exposure, and pending litigation"]
    draft["DiligenceEditor: Merge the specialist findings into a draft diligence report"]
    redteam["RedTeamAgent: Challenge every bullish claim in the draft report; stress-test projections and surface contradictions"]
    memo["MemoAgent: Produce the final structured memo: summary, findings, risks, recommendation - incorporating the red-team findings"]
    financial --> draft
    technical --> draft
    regulatory --> draft
    draft --> redteam
    draft --> memo
    redteam --> memo
    classDef done fill:#eef0e4,stroke:#5a7742,color:#3a4d2b
    classDef failed fill:#f3e0dd,stroke:#8c3b2e,color:#66291f
    classDef skipped fill:#eceae3,stroke:#8a8578,color:#57534a
    classDef running fill:#f5ead0,stroke:#9a7b2d,color:#5c4a1e
    class financial,technical,regulatory,draft,redteam,memo done
